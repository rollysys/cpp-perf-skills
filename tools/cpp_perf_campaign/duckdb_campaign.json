{
  "campaign_id": "duckdb-smoke",
  "repo_root": "/path/to/duckdb",
  "runtime_root": ".cpp-perf/campaigns/duckdb-smoke",
  "discover": {
    "include_globs": [
      "src/execution/**/*.cpp",
      "src/function/**/*.cpp",
      "src/optimizer/**/*.cpp",
      "src/storage/**/*.cpp",
      "src/parallel/**/*.cpp",
      "extension/**/*.cpp"
    ],
    "exclude_globs": [
      ".git/**",
      ".cpp-perf/**",
      "build/**",
      "third_party/**",
      "test/**",
      "benchmark/**",
      "data/**"
    ],
    "shard_depth": 2,
    "max_targets": 1200
  },
  "budget": {
    "max_attempts_per_target": 5,
    "max_low_gain_streak": 2,
    "stale_after_seconds": 3600,
    "heartbeat_interval_seconds": 10
  },
  "selection": {
    "keep_min_speedup": 1.03,
    "low_gain_speedup": 1.01
  },
  "strategies": [
    {
      "name": "vectorize",
      "kind": "explore",
      "max_passes": 1
    },
    {
      "name": "layout",
      "kind": "exploit",
      "max_passes": 2
    },
    {
      "name": "branch",
      "kind": "explore",
      "max_passes": 1
    },
    {
      "name": "prefetch",
      "kind": "exploit",
      "max_passes": 2
    }
  ],
  "hooks": {
    "prepare_case": [
      "python3",
      "{controller_root}/tools/cpp_perf_campaign/hooks/duckdb_prepare_case.py",
      "--repo-root",
      "{repo_root}",
      "--target",
      "{target_path}",
      "--case-dir",
      "{case_dir}"
    ],
    "baseline": [
      "python3",
      "{controller_root}/tools/cpp_perf_campaign/hooks/duckdb_baseline.py",
      "--repo-root",
      "{repo_root}",
      "--case-dir",
      "{case_dir}"
    ],
    "optimize": [
      "python3",
      "{controller_root}/tools/cpp_perf_campaign/hooks/duckdb_optimize.py",
      "--repo-root",
      "{repo_root}",
      "--case-dir",
      "{case_dir}",
      "--strategy",
      "{strategy}"
    ],
    "benchmark": [
      "python3",
      "{controller_root}/tools/cpp_perf_campaign/hooks/duckdb_benchmark.py",
      "--repo-root",
      "{repo_root}",
      "--case-dir",
      "{case_dir}"
    ]
  }
}
