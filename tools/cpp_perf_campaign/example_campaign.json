{
  "campaign_id": "demo",
  "repo_root": ".",
  "runtime_root": ".cpp-perf/campaigns/demo",
  "discover": {
    "include_globs": [
      "src/**/*.cc",
      "src/**/*.cpp",
      "src/**/*.cxx",
      "include/**/*.h",
      "include/**/*.hpp"
    ],
    "exclude_globs": [
      ".git/**",
      ".cpp-perf/**",
      "build/**",
      "third_party/**",
      "vendor/**",
      "reference/**"
    ],
    "shard_depth": 2,
    "max_targets": 500
  },
  "budget": {
    "max_attempts_per_target": 4,
    "max_low_gain_streak": 2,
    "stale_after_seconds": 1800,
    "heartbeat_interval_seconds": 5
  },
  "selection": {
    "keep_min_speedup": 1.05,
    "low_gain_speedup": 1.01
  },
  "strategies": [
    {
      "name": "vectorize",
      "kind": "explore",
      "max_passes": 1
    },
    {
      "name": "layout",
      "kind": "exploit",
      "max_passes": 2
    },
    {
      "name": "branch",
      "kind": "explore",
      "max_passes": 1
    }
  ],
  "hooks": {
    "prepare_case": [
      "python3",
      "your_prepare_case.py",
      "--target",
      "{target_path}",
      "--case-dir",
      "{case_dir}"
    ],
    "baseline": [
      "python3",
      "your_baseline_runner.py",
      "--case-dir",
      "{case_dir}"
    ],
    "optimize": [
      "python3",
      "your_optimizer.py",
      "--case-dir",
      "{case_dir}",
      "--strategy",
      "{strategy}"
    ],
    "benchmark": [
      "python3",
      "your_benchmark_runner.py",
      "--case-dir",
      "{case_dir}"
    ]
  }
}
